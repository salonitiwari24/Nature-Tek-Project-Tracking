{
  "name": "nature-tek-solar-pms",
  "version": "0.1.0",
  "private": true,
  "description": "Nature Tek Solar – Project Tracking & Management System",
  "scripts": {
    "dev": "turbo run dev",
    "build": "turbo run build",
    "lint": "turbo run lint",
    "test": "turbo run test",
    "db:generate": "pnpm --filter @nature-tek/database db:generate",
    "db:migrate": "pnpm --filter @nature-tek/database db:migrate",
    "db:push": "pnpm --filter @nature-tek/database db:push",
    "db:seed": "pnpm --filter @nature-tek/database db:seed",
    "docker:up": "docker compose up -d",
    "docker:down": "docker compose down"
  },
  "engines": {
    "node": ">=20.0.0",
    "pnpm": ">=9.0.0"
  },
  "packageManager": "pnpm@9.15.0",
  "devDependencies": {
    "prisma": "^5.22.0",
    "turbo": "^2.9.17"
  }
}
